# ⚠️ IMPORTANT: Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub - it's in .gitignore for security

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_API_KEY=your-gemini-api-key-here
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# Database (local dev - Cloud SQL on production)
DATABASE_URL=postgresql+asyncpg://postgres:crisis_dev@localhost:5432/crisiscommand

# Google Workspace
CHAT_SPACE_ID=spaces/YOUR_SPACE_ID
DOCS_FOLDER_ID=your-google-docs-folder-id
ONCALL_EMAIL=your-email@company.com

# Service Account (for OAuth)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Security
SIMULATOR_SECRET=your-simulator-secret-key

# URLs
WEBHOOK_URL=http://localhost:8000/webhook

# GitHub (used by GitHub MCP server for deployment & commit analysis)
GITHUB_TOKEN=                  # GitHub personal access token (repo read scope)
GITHUB_REPO=owner/repo-name    # e.g. myorg/payments-platform

# Cloud Logging (used by Cloud Logging MCP server for log search)
GOOGLE_CLOUD_PROJECT=          # GCP project ID (e.g. my-project-123); leave blank for demo mode

# Optional feature flags
# Local development defaults to "safe mode" unless running on Cloud Run.
# Uncomment to force-enable cloud integrations from your laptop.
# ENABLE_DATABASE=true
# ENABLE_EXTERNAL_ACTIONS=true
# ENABLE_LLM_CLASSIFIER=true
# ENABLE_GENAI_FEATURES=true
# MCP_TRANSPORT=stdio
# CHAT_MCP_URL=http://127.0.0.1:8001/sse
# DOCS_MCP_URL=http://127.0.0.1:8002/sse
# CALENDAR_MCP_URL=http://127.0.0.1:8003/sse
# GITHUB_MCP_URL=http://127.0.0.1:8004/sse
# LOGGING_MCP_URL=http://127.0.0.1:8005/sse
