# ⚠️ IMPORTANT: Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub - it's in .gitignore for security

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_API_KEY=your-gemini-api-key-here
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# Database (local dev - Cloud SQL on production)
DATABASE_URL=postgresql+asyncpg://postgres:crisis_dev@localhost:5432/crisiscommand

# Google Workspace
CHAT_SPACE_ID=spaces/YOUR_SPACE_ID
DOCS_FOLDER_ID=your-google-docs-folder-id
ONCALL_EMAIL=your-email@company.com

# Service Account (for OAuth)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Security
SIMULATOR_SECRET=your-simulator-secret-key

# URLs
WEBHOOK_URL=http://localhost:8000/webhook
